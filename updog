#!/usr/bin/env python3

"""
Minimal HTTP server with directory browsing and file upload support.
"""

import os
import posixpath
import http.server
import urllib.parse
import html
import shutil
import mimetypes
import re
from io import BytesIO
from email.parser import BytesFeedParser
from email.policy import default


class SimpleHTTPRequestHandler(http.server.BaseHTTPRequestHandler):
    """
    Handles basic HTTP GET, HEAD, and POST requests.

    - Serves files from the current working directory.
    - Generates directory listings.
    - Accepts file uploads via multipart/form-data.
    """

    # --- HTTP METHODS -----------------------------------------------------

    def do_GET(self):
        """Handle GET: send requested file or directory listing."""
        file_obj = self.send_head()
        if file_obj:
            self.copyfile(file_obj, self.wfile)
            file_obj.close()


    def do_HEAD(self):
        """Handle HEAD: send headers only (no body)."""
        file_obj = self.send_head()
        if file_obj:
            file_obj.close()


    def do_POST(self):
        """Handle POST: process multipart upload and return result page."""
        self._upload_result = None

        success, result = self.handle_multipart_stream()
        self._upload_result = result

        # Build simple HTML response
        response = BytesIO()
        response.write(
                b'<!DOCTYPE html PUBLIC "-//W3C//DTD HTML 3.2 Final//EN">')
        response.write(b"<html>\n<title>Upload Result Page</title>\n")
        response.write(b"<body>\n<h2>Upload Result Page</h2>\n<hr>\n")

        # Show upload outcome
        if success:
            response.write(b"<strong>Success:</strong><br>")
            for path in result:
                response.write(html.escape(path).encode() + b"<br>")
        else:
            response.write(b"<strong>Failed:</strong><br>")
            response.write(html.escape(str(result)).encode())

        # Link back to referring page
        referer = self.headers.get("referer", "/")
        response.write(f'<br><a href="{referer}">BACK</a>'.encode())

        response.write(b"</body>\n</html>\n")

        # Send response headers and body
        length = response.tell()
        response.seek(0)

        self.send_response(200)
        self.send_header("Content-Type", "text/html")
        self.send_header("Content-Length", str(length))
        self.end_headers()

        self.copyfile(response, self.wfile)
        response.close()


    def handle_multipart_stream(self):
        """Parse multipart/form-data stream and save uploaded files."""
        content_type = self.headers.get("Content-Type")
        content_length = int(self.headers.get("Content-Length", 0))

        # Validate multipart boundary
        if not content_type or "boundary=" not in content_type:
            return False, "Invalid multipart request"

        boundary = content_type.split("boundary=")[1].encode()
        boundary_line = b"--" + boundary
        end_boundary_line = b"--" + boundary + b"--"

        remaining = content_length
        upload_dir = self.translate_path(self.path)
        uploaded_files = []

        try:
            # Expect initial boundary line
            line = self.rfile.readline()
            remaining -= len(line)

            if boundary_line not in line:
                return False, "Malformed multipart data"

            # Process each part
            while remaining > 0:
                # Read part headers
                headers = {}
                while True:
                    line = self.rfile.readline()
                    remaining -= len(line)

                    if line in (b"\r\n", b"\n", b""):
                        break

                    key, _, value = line.decode().partition(":")
                    headers[key.strip().lower()] = value.strip()

                # Extract filename from Content-Disposition
                disposition = headers.get("content-disposition", "")
                match = re.search(r'filename="(.+?)"', disposition)

                if not match:
                    return False, "Missing filename"

                # Prevent directory traversal
                filename = os.path.basename(match.group(1))
                filepath = os.path.join(upload_dir, filename)

                # Write file content until next boundary
                with open(filepath, "wb") as f:
                    prev_line = self.rfile.readline()
                    remaining -= len(prev_line)

                    while remaining > 0:
                        line = self.rfile.readline()
                        remaining -= len(line)

                        if boundary_line in line or end_boundary_line in line:
                            prev_line = prev_line.rstrip(b"\r\n")
                            f.write(prev_line)
                            uploaded_files.append(filepath)
                            break

                        f.write(prev_line)
                        prev_line = line

                # Stop if final boundary reached
                if end_boundary_line in line:
                    break

            if not uploaded_files:
                return False, "No files uploaded"

            return True, uploaded_files

        except Exception as e:
            return False, str(e)


    def log_request(self, code='-', size='-'):
        """Log request and uploaded file paths (if any)."""
        super().log_request(code, size)

        if not hasattr(self, "_upload_result"):
            return

        result = self._upload_result
        if not result:
            return

        # Pretty-print uploaded paths in tree style
        if isinstance(result, list):
            for i, path in enumerate(result):
                branch = "└" if i == len(result) - 1 else "├"
                self.log_message("  %s %s", branch, path)
        else:
            self.log_message("  └ %s", result)

        self._upload_result = None


    # --- FILE SERVING -----------------------------------------------------

    def send_head(self):
        """Resolve path and send headers for file or directory."""
        path = self.translate_path(self.path)

        # Handle directory requests
        if os.path.isdir(path):
            # Redirect if missing trailing slash
            if not self.path.endswith("/"):
                self.send_response(301)
                self.send_header("Location", self.path + "/")
                self.end_headers()
                return None

            # Serve index file if present
            for index_name in ("index.html", "index.htm"):
                index_path = os.path.join(path, index_name)
                if os.path.exists(index_path):
                    path = index_path
                    break
            else:
                # Otherwise generate listing
                return self.list_directory(path)

        # Open requested file
        try:
            file_obj = open(path, "rb")
        except OSError:
            self.send_error(404, "File not found")
            return None

        fs = os.fstat(file_obj.fileno())

        # Send file metadata
        self.send_response(200)
        self.send_header("Content-Type", "application/octet-stream")
        self.send_header("Content-Length", str(fs.st_size))
        self.send_header("Last-Modified", self.date_time_string(fs.st_mtime))
        self.end_headers()

        return file_obj


    def list_directory(self, path):
        """Generate simple HTML directory listing with upload form."""
        try:
            entries = os.listdir(path)
        except OSError:
            self.send_error(404, "No permission to list directory")
            return None

        entries.sort(key=str.lower)

        response = BytesIO()
        display_path = html.escape(urllib.parse.unquote(self.path))

        # Build HTML listing page
        response.write(
                b'<!DOCTYPE html PUBLIC "-//W3C//DTD HTML 3.2 Final//EN">')
        response.write(f"<html>\n<title>Directory listing for \
                {display_path}</title>\n".encode())
        response.write(f"<body>\n<h2>Directory listing for \
                {display_path}</h2>\n<hr>\n".encode())

        # Upload form
        response.write(
            b'<form enctype="multipart/form-data" method="post">'
            b'<input name="file" type="file" multiple/>'
            b'<input type="submit" value="upload"/></form>\n<hr>\n<ul>\n'
        )

        # List directory contents
        for name in entries:
            full_path = os.path.join(path, name)
            display_name = link_name = name

            if os.path.isdir(full_path):
                display_name += "/"
                link_name += "/"

            if os.path.islink(full_path):
                display_name += "@"

            response.write(
                f'<li><a href="{urllib.parse.quote(link_name)}">'
                f"{html.escape(display_name)}</a>\n".encode()
            )

        response.write(b"</ul>\n<hr>\n</body>\n</html>\n")

        # Send listing response
        length = response.tell()
        response.seek(0)

        self.send_response(200)
        self.send_header("Content-Type", "text/html")
        self.send_header("Content-Length", str(length))
        self.end_headers()

        return response

    # --- UTILITIES --------------------------------------------------------

    def translate_path(self, path):
        """Convert URL path to safe local filesystem path."""
        # Strip query and fragment
        path = path.split("?", 1)[0].split("#", 1)[0]
        path = posixpath.normpath(urllib.parse.unquote(path))

        words = [w for w in path.split("/") if w]
        local_path = os.getcwd()

        # Rebuild path safely, ignoring . and ..
        for word in words:
            _, word = os.path.splitdrive(word)
            _, word = os.path.split(word)
            if word in (os.curdir, os.pardir):
                continue
            local_path = os.path.join(local_path, word)

        return local_path


    def copyfile(self, source, output):
        """Stream file content to client."""
        shutil.copyfileobj(source, output)


if __name__ == "__main__":
    http.server.test(
            SimpleHTTPRequestHandler,
            http.server.ThreadingHTTPServer,
            port=9090)
