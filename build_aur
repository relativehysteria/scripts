#!/bin/sh
set -e

# Check if a package name is provided
if [ -z "$1" ]; then
    echo "Usage: $0 <package>"
    exit 1
fi

pkg="$1"
tmpdir=$(mktemp -d)

cleanup() {
    echo "Cleaning up..."
    rm -rf "$tmpdir"
}

trap cleanup EXIT INT TERM

echo "Cloning AUR repo for '$pkg'..."
git clone "https://aur.archlinux.org/${pkg}.git" "$tmpdir/$pkg" \
    || { echo "Failed to clone AUR repo."; exit 1; }

cd "$tmpdir/$pkg"

echo
echo "PKGBUILD downloaded."
echo "Review files before building:"
echo "--------------------------------"
ls -1
echo "--------------------------------"
echo "Press [Enter] to continue, Ctrl+C to cancel."
read -r

makepkg -si
