#!/usr/bin/env python
import subprocess
from http.server import BaseHTTPRequestHandler, HTTPServer
from html import escape

HOST = "0.0.0.0"
PORT = 9090

def get_initial_volume():
    try:
        out = subprocess.check_output(
            ["wpctl", "get-volume", "@DEFAULT_AUDIO_SINK@"],
            text=True
        ).strip()
        # Expected: "Volume: 0.61"
        value = float(out.split()[1])
        return value
    except Exception as e:
        print("Failed to get initial volume:", e)
        return 1.0  # fallback to 100%

INITIAL_VOLUME = get_initial_volume()
LOW_VOLUME = 0.55

print(f"Initial volume: {INITIAL_VOLUME:.2f}")
print(f"Low volume: {LOW_VOLUME:.2f}")

COMMANDS = {
    "hibernate": ["sudo", "loginctl", "hibernate"],
    "sleep": ["daily", "sleep"],
    "shutdown": ["sudo", "shutdown", "-h", "now"],
    "volume_low": [
        "wpctl", "set-volume", "@DEFAULT_AUDIO_SINK@", str(LOW_VOLUME)
    ],
    "volume_original": [
        "wpctl", "set-volume", "@DEFAULT_AUDIO_SINK@", str(INITIAL_VOLUME)
    ],
}

class Handler(BaseHTTPRequestHandler):
    def do_GET(self):
        if self.path == "/":
            self.serve_index()
            return

        name = self.path.lstrip("/")
        cmd = COMMANDS.get(name)
        if cmd:
            self.run_command(cmd)
            return

        self.send_error(404)

    def serve_index(self):
        self.send_response(200)
        self.send_header("Content-Type", "text/html")
        self.end_headers()

        items = "\n".join(
            f'<h1><a href="/{escape(name)}">{escape(name).upper()}</a></h1><br>'
            for name in COMMANDS
        )

        html = f"""\
<!doctype html>
<html>
<head><title>cmd server</title></head>
<body>
{items}
</body>
</html>
"""
        self.wfile.write(html.encode())

    def run_command(self, cmd):
        self.send_response(200)
        self.end_headers()
        self.wfile.write(b"OK\n")
        subprocess.Popen(cmd)

    def log_message(self, *_):
        pass


if __name__ == "__main__":
    print(f"Listening on http://{HOST}:{PORT}")
    HTTPServer((HOST, PORT), Handler).serve_forever()
